# Server
NODE_ENV=development
PORT=5003
SERVICE_NAME=eventflow-ticket-service
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://localhost:27017/ticketdb

# JWT — must match the secret used by the auth/user service
JWT_SECRET=change_me_in_production

# Inter-service URLs
EVENT_SERVICE_URL=http://event-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3004

# CORS
CLIENT_URL=http://localhost:3000
